---
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout title="游戏">
  <section class="container mx-auto px-4">
    <h1 class="text-3xl font-bold mb-8 text-center">游戏列表</h1>
    <div class="games-grid">
      <a href="/games/snake" class="game-card">
        <div class="game-card-content">
          <h2 class="text-xl font-semibold mb-2">贪吃蛇</h2>
          <p class="text-gray-600 mb-4">经典的贪吃蛇游戏，控制蛇头吃食物，越长越好！</p>
          <div class="play-button">开始游戏</div>
        </div>
      </a>
      <a href="/games/gomoku" class="game-card">
        <div class="game-card-content">
          <h2 class="text-xl font-semibold mb-2">五子棋</h2>
          <p class="text-gray-600 mb-4">经典的五子棋游戏，与 AI 对战，挑战你的棋艺！</p>
          <div class="play-button">开始游戏</div>
        </div>
      </a>
    </div>
  </section>

  <style>
    .games-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 2rem;
      max-width: 1000px;
      margin: 0 auto;
    }

    .game-card {
      display: block;
      background: #f9fafb;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 1.5rem;
      transition: all 0.3s ease;
      text-decoration: none;
      color: inherit;
    }

    .game-card:hover {
      transform: translateY(-4px);
      box-shadow:
        0 10px 25px -5px rgba(0, 0, 0, 0.1),
        0 10px 10px -5px rgba(0, 0, 0, 0.04);
      border-color: #d1d5db;
    }

    .game-card-content {
      display: flex;
      flex-direction: column;
      height: 100%;
    }

    .game-card h2 {
      color: #1f2937;
      margin-bottom: 0.5rem;
    }

    .game-card p {
      flex-grow: 1;
      margin-bottom: 1rem;
    }

    .play-button {
      background: #3b82f6;
      color: white;
      padding: 0.75rem 1.5rem;
      border-radius: 6px;
      text-align: center;
      font-weight: 500;
      transition: background-color 0.2s ease;
    }

    .play-button:hover {
      background: #2563eb;
    }
  </style>
</BaseLayout>
