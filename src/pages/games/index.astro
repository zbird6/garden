---
import BaseLayout from '../../layouts/BaseLayout.astro'
import SnakeGame from '../../games/snake/index.vue'
---

<BaseLayout title="游戏">
  <section class="container mx-auto px-4">
    <header class="page-header">
      <h1>原生游戏</h1>
      <p class="subtitle">使用 HTML5 Canvas + 原生 JavaScript 构建的游戏</p>
    </header>

    <div class="games-section">
      <div class="game-wrapper">
        <h2>贪吃蛇</h2>
        <SnakeGame client:load />
      </div>
    </div>
  </section>

  <style>
    .page-header {
      text-align: center;
      margin-bottom: 3rem;
      padding: 2rem 0;
    }

    .page-header h1 {
      font-size: 2.5rem;
      margin: 0 0 1rem 0;
      color: #1f2937;
    }

    .subtitle {
      font-size: 1.125rem;
      color: #6b7280;
      margin: 0;
    }

    .games-section {
      max-width: 800px;
      margin: 0 auto;
    }

    .game-wrapper {
      margin-bottom: 4rem;
    }

    .game-wrapper h2 {
      text-align: center;
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
      color: #1f2937;
    }

    @media (max-width: 768px) {
      .page-header h1 {
        font-size: 2rem;
      }

      .subtitle {
        font-size: 1rem;
      }

      .game-wrapper h2 {
        font-size: 1.25rem;
      }
    }
  </style>
</BaseLayout>
