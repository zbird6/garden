---
import BaseLayout from '../../layouts/BaseLayout.astro'
import SnakeGame from '../../games/snake/index.vue'
---

<BaseLayout title="游戏">
  <section class="container mx-auto px-4">
    <div class="games-section">
      <div class="game-wrapper">
        <h2>贪吃蛇</h2>
        <SnakeGame client:load />
      </div>
    </div>
  </section>

  <style>
    .games-section {
      max-width: 800px;
      margin: 0 auto;
    }

    .game-wrapper {
      margin-bottom: 4rem;
    }

    .game-wrapper h2 {
      text-align: center;
      font-size: 1.5rem;
      margin-bottom: 1.5rem;
      color: #1f2937;
    }

    @media (max-width: 768px) {
      .game-wrapper h2 {
        font-size: 1.25rem;
      }
    }
  </style>
</BaseLayout>
