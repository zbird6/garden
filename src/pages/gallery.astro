---
import BaseLayout from '../layouts/BaseLayout.astro'
import Gallery from '../components/Gallery.vue'
---

<BaseLayout title="图片展示">
  <section class="container mx-auto px-4">
    <header class="page-header">
      <h1>图片展示</h1>
      <p class="subtitle">精选风景照片，点击可查看大图并跳转到原文</p>
    </header>

    <Gallery client:load />
  </section>

  <style>
    .page-header {
      text-align: center;
      margin-bottom: 3rem;
      padding: 2rem 0;
    }

    .page-header h1 {
      font-size: 2.5rem;
      margin: 0 0 1rem 0;
      color: #1f2937;
    }

    .subtitle {
      font-size: 1.125rem;
      color: #6b7280;
      margin: 0;
    }

    @media (max-width: 768px) {
      .page-header h1 {
        font-size: 2rem;
      }

      .subtitle {
        font-size: 1rem;
      }
    }
  </style>
</BaseLayout>
