---
interface Props {
  title: string
  description?: string
}

const { title, description = '个人静态网站 - 博客、图片展示与小游戏' } = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site)
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title} - ZGarden</title>
  </head>
  <body class="bg-gray-50 text-gray-800">
    <body>
      <header>
        <nav class="navbar">
          <div class="container mx-auto px-4">
            <a href="/" class="logo">ZGarden</a>
            <ul class="nav-links">
              <li>
                <a href="/">首页</a>
              </li>
              <li>
                <a href="/blog">博客</a>
              </li>
              <li>
                <a href="/games">小游戏</a>
              </li>
            </ul>
          </div>
        </nav>
      </header>

      <main class="main-content">
        <slot />
      </main>

      <footer class="footer">
        <div class="container mx-auto px-4">
          <p>&copy; {new Date().getFullYear()} ZGarden. All rights reserved.</p>
        </div>
      </footer>

      <style is:global>
        .navbar {
          @apply bg-white shadow-sm sticky top-0 z-50;
        }

        .navbar .container {
          @apply flex items-center justify-between py-4;
        }

        .logo {
          @apply text-2xl font-bold text-sky-500;
        }

        .nav-links {
          @apply flex gap-8 list-none m-0 p-0;
        }

        .nav-links a {
          @apply text-gray-500 font-medium no-underline transition-colors duration-200;
        }

        .nav-links a:hover {
          @apply text-sky-500;
        }

        .main-content {
          @apply min-h-[calc(100vh-140px)] py-8;
        }

        .footer {
          @apply bg-gray-800 text-white py-8 mt-16;
        }

        .footer p {
          @apply text-center m-0;
        }

        @media (max-width: 768px) {
          .navbar .container {
            @apply flex-col gap-4;
          }

          .nav-links {
            @apply gap-4 text-sm;
          }
        }
      </style>
    </body>
  </body>
</html>
